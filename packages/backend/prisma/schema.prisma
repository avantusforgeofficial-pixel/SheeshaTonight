// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== AUTH & USERS ====================

enum UserRole {
  CUSTOMER
  VENDOR
  ADMIN
  MANAGER
  ACCOUNTANT
  ORDER_PROCESSOR
}

model User {
  id                String   @id @default(cuid())
  email             String   @unique
  phone             String?  @unique
  password          String
  firstName         String
  lastName          String
  profileImage      String?
  role              UserRole @default(CUSTOMER)
  isActive          Boolean  @default(true)
  isVerified        Boolean  @default(false)
  emailVerifiedAt   DateTime?
  phoneVerifiedAt   DateTime?
  lastLoginAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  vendor            Vendor?
  customer          Customer?
  orders            Order[]
  reviews           Review[]
  refreshTokens     RefreshToken[]
  auditLogs         AuditLog[]

  @@index([email])
  @@index([role])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// ==================== ROLES & PERMISSIONS ====================

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  permissions Permission[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Permission {
  id    String @id @default(cuid())
  name  String @unique
  roles Role[]
}

// ==================== CUSTOMER ====================

model Customer {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  addressLine1    String?
  addressLine2    String?
  city            String?
  state           String?
  zipCode         String?
  country         String?
  latitude        Float?
  longitude       Float?
  preferredCurrency String @default("AED")
  preferredLanguage String @default("en")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

// ==================== VENDOR ====================

model Vendor {
  id                    String      @id @default(cuid())
  userId                String      @unique
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeName             String
  storeSlug             String      @unique
  description           String?
  logo                  String?
  banner                String?
  address               String
  city                  String
  state                 String?
  zipCode               String
  country               String @default("AE")
  latitude              Float
  longitude             Float
  phone                 String
  website               String?
  
  // Vendor Status
  status                VendorStatus @default(PENDING)
  approvedAt            DateTime?
  rejectionReason       String?
  
  // KYC
  kycStatus             KYCStatus @default(PENDING)
  documentUrls          String[]
  
  // Rating
  averageRating         Float @default(0)
  totalReviews          Int   @default(0)
  
  // Subscription
  subscriptionPlan      SubscriptionPlan @default(SOLO)
  subscriptionEndsAt    DateTime?
  
  // Commission
  commissionRate        Float @default(0.15)
  
  // Account Details
  bankName              String?
  accountHolderName     String?
  accountNumber         String?
  iban                  String?
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  products              Product[]
  rentalCalendars       RentalCalendar[]
  orders                Order[]
  payouts               Payout[]
  subscriptions         VendorSubscription[]
  reviews               Review[]

  @@index([userId])
  @@index([storeSlug])
  @@index([city])
  @@index([status])
}

enum VendorStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED
  CLOSED
}

enum KYCStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
}

// ==================== PRODUCTS ====================

model Product {
  id              String   @id @default(cuid())
  vendorId        String
  vendor          Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  
  name            String
  slug            String
  description     String
  images          String[]
  category        String
  
  price           Float
  currency        String @default("AED")
  
  // Inventory
  quantity        Int @default(0)
  
  // Rental specific
  rentalDuration  String @enum(["HOURLY", "DAILY", "WEEKLY", "MONTHLY"])
  isActive        Boolean @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  orderItems      OrderItem[]
  rentalCalendars RentalCalendar[]

  @@index([vendorId])
  @@index([category])
  @@index([slug])
}

enum RentalDuration {
  HOURLY
  DAILY
  WEEKLY
  MONTHLY
}

// ==================== RENTAL CALENDAR ====================

model RentalCalendar {
  id          String   @id @default(cuid())
  vendorId    String
  vendor      Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  date        DateTime
  slots       Int
  availableSlots Int
  isBlocked   Boolean @default(false)
  blockReason String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([productId, date])
  @@index([vendorId])
  @@index([productId])
  @@index([date])
}

// ==================== ORDERS ====================

enum OrderStatus {
  PENDING
  CONFIRMED
  READY_FOR_PICKUP
  OUT_FOR_DELIVERY
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

model Order {
  id                String        @id @default(cuid())
  orderNumber       String        @unique
  
  customerId        String
  customer          User          @relation(fields: [customerId], references: [id])
  
  vendorId          String
  vendor            Vendor        @relation(fields: [vendorId], references: [id])
  
  items             OrderItem[]
  
  subtotal          Float
  taxAmount         Float @default(0)
  deliveryFee       Float @default(0)
  discount          Float @default(0)
  totalAmount       Float
  
  currency          String @default("AED")
  
  status            OrderStatus @default(PENDING)
  paymentStatus     PaymentStatus @default(PENDING)
  
  // Delivery info
  deliveryAddress   String
  deliveryLat       Float?
  deliveryLng       Float?
  estimatedDelivery DateTime?
  deliveredAt       DateTime?
  
  // Dates
  rentalStartDate   DateTime?
  rentalEndDate     DateTime?
  
  // Payment
  paymentMethod     String?
  transactionId     String?
  
  notes             String?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([customerId])
  @@index([vendorId])
  @@index([status])
  @@index([paymentStatus])
  @@index([orderNumber])
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  productId   String
  product     Product @relation(fields: [productId], references: [id])
  
  quantity    Int
  price       Float
  subtotal    Float
  
  createdAt   DateTime @default(now())

  @@index([orderId])
  @@index([productId])
}

// ==================== SUBSCRIPTIONS ====================

enum SubscriptionPlan {
  SOLO
  MASTER
  ADVANCED
}

model VendorSubscription {
  id        String              @id @default(cuid())
  vendorId  String
  vendor    Vendor              @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  
  plan      SubscriptionPlan
  price     Float
  currency  String @default("AED")
  
  status    SubscriptionStatus @default(ACTIVE)
  startDate DateTime
  endDate   DateTime
  renewAt   DateTime
  
  isAutoRenew Boolean @default(true)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vendorId])
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PENDING
}

// ==================== PAYOUTS ====================

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

model Payout {
  id            String       @id @default(cuid())
  vendorId      String
  vendor        Vendor       @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  
  amount        Float
  currency      String @default("AED")
  
  status        PayoutStatus @default(PENDING)
  
  paymentMethod String
  accountDetails String?
  
  processedAt   DateTime?
  failureReason String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([vendorId])
  @@index([status])
}

// ==================== REVIEWS & RATINGS ====================

model Review {
  id          String  @id @default(cuid())
  
  customerId  String
  customer    User    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  
  vendorId    String
  vendor      Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  
  rating      Int     @default(5)
  title       String?
  comment     String?
  images      String[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([customerId, vendorId])
  @@index([vendorId])
  @@index([customerId])
}

// ==================== AUDIT LOGS ====================

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  action    String
  entity    String
  entityId  String
  changes   Json?
  ipAddress String?
  userAgent String?
  
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
}
